RESEND_API_KEY=
# Optionnel : expéditeur vérifié chez Resend (sinon défaut test onboarding@resend.dev).
# RESEND_FROM=AVOLO <onboarding@resend.dev>
# Si Resend renvoie 403 : en test, n’envoie qu’à l’e-mail du compte Resend ; en prod, vérifie un domaine + RESEND_FROM.
# Vidéo de fond (Recherche, bandeau « Envie de partir ? »). MP4 ou WebM — ex. /videos/plage.mp4 ou URL HTTPS.
# Sans variable (ou chaîne vide) : vidéo par défaut Wikimedia Commons (vue aérienne plage / eau turquoise, 720p ~66 Mo).
# Pour n’afficher que l’image : VITE_DESTINATION_GUIDE_HERO_VIDEO=false
# VITE_DESTINATION_GUIDE_HERO_VIDEO=/videos/hero-destination.mp4

VITE_CITY_HERO_STORAGE_BUCKET=city-heroes
# Uniquement pour npm run upload:destinations (Dashboard → Settings → API → service_role). Ne pas mettre dans le front.
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio — utilisé par le plugin Vite (dev / preview). Ne jamais préfixer par VITE_.
GEMINI_API_KEY=
# Optionnel (défaut sans ligne : gemini-2.5-flash). En 429 : chaque modèle a souvent son propre quota gratuit — change de nom.
# Ex. GEMINI_MODEL=gemini-2.5-flash  ou  GEMINI_MODEL=gemini-2.0-flash  si gemini-2.5-flash-lite est à 20 req/j.
# GEMINI_MODEL=gemini-2.5-flash
# Programme jour par jour : quand true, l’API /api/gemini/itinerary refuse sans créateur (voir ci-dessous).
# GEMINI_ITINERARY_PREMIUM_ONLY=true
# GEMINI_CREATOR_ITINERARY=true
# Front : si true, les non-abonnés voient une modale Premium au clic sur « Générer un programme ».
# Abonné = user_metadata.premium true ou subscription_tier/plan/subscription = premium (ou pro). Bypass dev : VITE_CREATOR_ITINERARY=true
# VITE_ITINERARY_PREMIUM_ONLY=true
# VITE_CREATOR_ITINERARY=true
# Afficher quotas / erreurs API Gemini détaillés dans le guide (uniquement pour toi, pas en prod utilisateur).
# VITE_SHOW_GEMINI_DEV_ERRORS=true

# E-mails (séparés par des virgules) qui voient les messages d’erreur détaillés dans les toasts. Les autres utilisateurs voient un libellé générique (détails dans la console du navigateur).
# VITE_DEVELOPER_UI_EMAILS=ton@email.com

# Groq — conseils d'expert (tips) et programme sur mesure (itinéraire). LLM ultra-rapide.
# Clé gratuite sur https://console.groq.com (14 400 req/jour, modèle llama-3.3-70b-versatile).
# Clé côté SERVEUR uniquement (pas de préfixe VITE_).
# Sans clé : Gemini reste utilisé pour ces deux features.
GROQ_API_KEY=

# Foursquare Places API — lieux incontournables & activités pour les villes hors catalogue.
# Clé gratuite sur https://foursquare.com/developer (100 000 req/jour en free tier).
# Clé côté SERVEUR uniquement (pas de préfixe VITE_) — les appels passent par /api/foursquare/places.
# Sans clé : fallback sur le catalogue local + textes génériques (comportement actuel).
FOURSQUARE_API_KEY=